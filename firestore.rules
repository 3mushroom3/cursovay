rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(uid())).data; }
    function role() { return signedIn() ? userDoc().role : null; }
    function isAdmin() { return role() == 'admin'; }
    function isModerator() { return role() == 'moderator' || isAdmin(); }
    function isOwner(userId) { return signedIn() && userId == uid(); }

    match /users/{userId} {
      // get() на единственный документ — проверяем владельца или модератора
      allow get: if signedIn() && (isOwner(userId) || isModerator());
      // list (выборка коллекции) — только модераторы и администраторы
      allow list: if signedIn() && isModerator();
      allow create: if signedIn() && isOwner(userId);
      allow update: if signedIn() && (isOwner(userId) || isModerator());
      allow delete: if false;
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isModerator();
    }

    match /proposals/{proposalId} {
      function isPublic() { return resource.data.visibility == 'public'; }
      function isAuthor() { return isOwner(resource.data.authorId); }

      // list (выборка коллекции): любой аутентифицированный пользователь.
      // Видимость применяется на клиенте через PublicFeedPolicy.isVisibleInFeed().
      allow list: if signedIn();
      // get (одиночный документ): публичное, своё или модератор
      allow get: if signedIn() && (isPublic() || isAuthor() || isModerator());
      allow create: if signedIn();
      allow update: if signedIn() && (isModerator() || isAuthor());
      allow delete: if signedIn() && (isModerator() || isAuthor());

      match /history/{eventId} {
        allow read: if signedIn();
        allow create: if signedIn() && isModerator();
        allow update, delete: if false;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() &&
          request.resource.data.authorId == uid() &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() < 8000 &&
          request.resource.data.authorDisplayName is string &&
          request.resource.data.authorDisplayName.size() > 0 &&
          request.resource.data.authorDisplayName.size() <= 200;
        allow update, delete: if signedIn() &&
          (isModerator() || resource.data.authorId == uid());
      }

      match /votes/{voteUserId} {
        allow read: if signedIn();
        allow create, delete: if signedIn() && voteUserId == uid();
      }
    }
  }
}
